# 应用配置
NODE_ENV=development
PORT=8080

# 安全配置 - JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=24h

# 安全配置 - 加密主密钥 (必须32字节十六进制字符串)
# 使用: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=change-this-to-a-32-byte-hex-string-in-production

# 安全配置 - 会话密钥
SESSION_SECRET=change-this-session-secret-in-production

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=12305
DB_NAME=kpl

# 数据库连接池配置
DB_POOL_SIZE=10
DB_POOL_MAX_SIZE=20
DB_POOL_ACQUIRE_TIMEOUT=30000
DB_POOL_IDLE_TIMEOUT=60000

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_SIZE=1000

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# Socket配置
SOCKET_PORT=8888
SOCKET_HOST=0.0.0.0
SOCKET_TIMEOUT=300000
MAX_CONNECTIONS=1000
BATCH_PROCESSING_ENABLED=true
BATCH_SIZE=10
COMPRESSION_ENABLED=true
ERROR_RETRY_LIMIT=3

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# 数据导出配置
EXPORT_MAX_ROWS=10000
EXPORT_TIMEOUT=30000

    "cosr": "^5.0.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "http-errors": "^2.0.0",
    "iconv-lite": "^0.6.3",
